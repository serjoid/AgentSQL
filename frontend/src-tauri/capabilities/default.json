{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for SGBD — grants window controls, sidecar spawning, and file dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "backend", "sidecar": true }]
    },
    "shell:allow-execute",
    "dialog:default"
  ]
}
